        {"id": "func_quadratic_existence", "name": "★ 几何存在性 (Q24)", "level": 3, "importance": 10, "description": "压轴必考：等腰、直角、平行四边形存在性讨论。", "prerequisites": ["func_quadratic_basic", "geo_triangle_prop"], "common_misconceptions": ["漏掉分类讨论情况"]}
