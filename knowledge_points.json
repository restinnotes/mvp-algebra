{
  "version": "3.0",
  "source": "上海市初中数学学科教学基本要求",
  "categories": [
    {
      "id": "number_operations",
      "name": "数与运算",
      "nodes": [
        {
          "id": "num_divisibility",
          "name": "数的整除",
          "level": 2,
          "description": "理解因数、倍数、质数、合数的概念，掌握分解质因数的方法",
          "prerequisites": []
        },
        {
          "id": "num_real",
          "name": "实数",
          "level": 2,
          "description": "理解实数概念，掌握实数的四则运算和科学记数法",
          "prerequisites": ["num_divisibility"]
        }
      ]
    },
    {
      "id": "algebra",
      "name": "代数",
      "nodes": [
        {
          "id": "alg_expression",
          "name": "代数式与整式",
          "level": 2,
          "description": "掌握代数式的求值、整式运算",
          "prerequisites": []
        },
        {
          "id": "alg_fraction",
          "name": "分式",
          "level": 2,
          "description": "理解分式有意义的条件，掌握分式运算",
          "prerequisites": ["alg_expression"]
        },
        {
          "id": "alg_rational_root",
          "name": "二次根式",
          "level": 2,
          "description": "理解二次根式的概念，掌握运算方法",
          "prerequisites": ["num_real"]
        },
        {
          "id": "alg_equation",
          "name": "方程与方程组",
          "level": 2,
          "description": "掌握一元一次方程、一元二次方程、分式方程的解法",
          "prerequisites": ["alg_expression", "alg_fraction"]
        },
        {
          "id": "alg_inequality",
          "name": "一元一次不等式",
          "level": 2,
          "description": "掌握不等式性质和解不等式",
          "prerequisites": ["alg_equation"]
        },
        {
          "id": "alg_linear_func",
          "name": "一次函数",
          "level": 3,
          "description": "理解一次函数概念、图像与性质",
          "prerequisites": ["alg_equation", "alg_inequality"]
        },
        {
          "id": "alg_inverse_func",
          "name": "反比例函数",
          "level": 3,
          "description": "理解反比例函数概念、图像与性质",
          "prerequisites": ["alg_linear_func"]
        },
        {
          "id": "alg_quadratic_func",
          "name": "二次函数",
          "level": 3,
          "description": "掌握二次函数的图像与性质，会求解析式",
          "prerequisites": ["alg_linear_func", "alg_equation"]
        }
      ]
    },
    {
      "id": "geometry",
      "name": "几何",
      "nodes": [
        {
          "id": "geo_triangle_basic",
          "name": "三角形基础",
          "level": 2,
          "description": "理解三角形内角和、外角性质",
          "prerequisites": []
        },
        {
          "id": "geo_congruent_tri",
          "name": "全等三角形",
          "level": 3,
          "description": "掌握SSS、SAS、ASA、AAS、HL判定方法",
          "prerequisites": ["geo_triangle_basic"]
        },
        {
          "id": "geo_similar_tri",
          "name": "相似三角形",
          "level": 3,
          "description": "掌握相似三角形的判定与性质",
          "prerequisites": ["geo_congruent_tri"]
        },
        {
          "id": "geo_trig_ratio",
          "name": "锐角三角比",
          "level": 3,
          "description": "掌握sin、cos、tan的含义和计算",
          "prerequisites": ["geo_triangle_basic"]
        },
        {
          "id": "geo_parallelogram",
          "name": "平行四边形",
          "level": 2,
          "description": "掌握平行四边形的性质与判定",
          "prerequisites": ["geo_triangle_basic"]
        },
        {
          "id": "geo_rectangle",
          "name": "矩形、菱形、正方形",
          "level": 3,
          "description": "掌握特殊平行四边形的性质与判定",
          "prerequisites": ["geo_parallelogram"]
        },
        {
          "id": "geo_circle_basic",
          "name": "圆的基本性质",
          "level": 2,
          "description": "理解圆的基本概念、垂径定理、圆周角定理",
          "prerequisites": ["geo_triangle_basic"]
        },
        {
          "id": "geo_circle_relation",
          "name": "圆与直线的位置关系",
          "level": 3,
          "description": "掌握切线的判定与性质",
          "prerequisites": ["geo_circle_basic"]
        },
        {
          "id": "geo_motion_fold",
          "name": "翻折",
          "level": 3,
          "description": "理解翻折变换的性质，对应边角相等",
          "prerequisites": ["geo_congruent_tri"]
        },
        {
          "id": "geo_motion_rotation",
          "name": "旋转",
          "level": 3,
          "description": "理解旋转的性质，旋转对应点关系",
          "prerequisites": ["geo_congruent_tri"]
        }
      ]
    },
    {
      "id": "statistics",
      "name": "统计与概率",
      "nodes": [
        {
          "id": "stat_data",
          "name": "统计量",
          "level": 2,
          "description": "理解平均数、中位数、众数、方差等统计量",
          "prerequisites": []
        },
        {
          "id": "stat_probability",
          "name": "概率",
          "level": 2,
          "description": "掌握概率的计算方法",
          "prerequisites": []
        }
      ]
    }
  ]
}
